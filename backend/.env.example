# Copy this to .env and fill in your values.
# Never commit .env to git.

# PostgreSQL connection string
# Local: postgresql://postgres:password@localhost:5432/retail_analytics
# Hosted: get this from your provider (Railway, Supabase, Neon, etc.)
DATABASE_URL=postgresql://postgres:password@localhost:5432/retail_analytics

# JWT secret — generate a strong random string for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_this_with_a_64_byte_random_hex_string
JWT_EXPIRES_IN=7d

# Server
PORT=3001
NODE_ENV=development

# File upload limits
MAX_FILE_SIZE_MB=25
UPLOAD_TEMP_DIR=./uploads/temp

# CORS: the URL of your frontend (Vercel URL in production)
CORS_ORIGIN=http://localhost:5173
